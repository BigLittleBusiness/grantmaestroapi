doctype html
html
  head
    meta(charset="UTF-8")
    title Welcome to Our Platform 1
    style.
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        padding: 20px;
      }
      .container {
        max-width: 600px;
        margin: auto;
        background: #ffffff;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }
      h1 {
        color: #333;
      }
      p {
        font-size: 16px;
        color: #555;
      }
      .button {
        display: inline-block;
        padding: 10px 20px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 5px;
        margin-top: 20px;
      }
  body
    .container
      h1 Welcome,
      p **Subscription Info:** #{subscriptionInfo}
      p **Payment For User Id:** #{payment_made_for}
      p **Stripe subscriptionId:** #{stripe_subscription_id}
      .footer
        p Best regards,  
        p **The Grant Maestro Team**

      // Add logo here
      .logo
        img(src="https://grantmaestro.com/static/media/color_logo.78f59280492b09b46c32.png" alt="Grant Maestro Logo" width="150")